@page
@model AutoGarageManager.Pages.Admin.SettingsModel
@{
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Cài Đặt";
}

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-0">
                <h2 class="h6 mb-0">Thông tin cửa hàng</h2>
            </div>
            <div class="card-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label">Tên cửa hàng</label>
                        <input class="form-control" value="Auto Garage Manager" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input class="form-control" value="123 Đường ABC, Quận 1, TP. HCM" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input class="form-control" value="(028) 1234 5678" readonly />
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-0">
                <h2 class="h6 mb-0">Tùy chọn hệ thống</h2>
            </div>
            <div class="card-body">
                <form>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" checked disabled />
                        <label class="form-check-label">Kích hoạt thông báo qua email</label>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" checked disabled />
                        <label class="form-check-label">Cho phép người dùng đăng ký</label>
                    </div>
                    <button class="btn btn-primary" disabled>Lưu cài đặt</button>
                </form>
            </div>
        </div>
    </div>
</div>
