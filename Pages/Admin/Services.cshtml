@page
@model AutoGarageManager.Pages.Admin.ServicesModel
@{
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Dịch Vụ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Dịch Vụ</h2>
    <a class="btn btn-dark" href="#">+ Thêm Dịch Vụ</a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Tên dịch vụ</th>
                    <th>Mô tả</th>
                    <th>Giá</th>
                    <th style="width: 140px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Thay dầu động cơ</td>
                    <td>Thay dầu và lọc dầu</td>
                    <td>350.000₫</td>
                    <td>
                        <a class="text-decoration-none" href="#">Sửa</a>
                        <span class="mx-1">|</span>
                        <a class="text-danger text-decoration-none" href="#">Xóa</a>
                    </td>
                </tr>
                <tr>
                    <td>Bảo dưỡng tổng quát</td>
                    <td>Kiểm tra toàn bộ hệ thống</td>
                    <td>550.000₫</td>
                    <td>
                        <a class="text-decoration-none" href="#">Sửa</a>
                        <span class="mx-1">|</span>
                        <a class="text-danger text-decoration-none" href="#">Xóa</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
