@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "Tổng Quan";
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    Func<string, string> navClass = page => currentPage.Equals(page, StringComparison.OrdinalIgnoreCase) ? "nav-link active" : "nav-link";
}

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Auto Garage Manager (Admin)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="admin-body">
    <div class="d-flex">
        <aside class="admin-sidebar">
            <div class="admin-logo mb-4">
                <span class="fw-bold">Auto Garage Manager</span>
            </div>
            <nav class="nav flex-column admin-menu">
                <a class="@(navClass("/Admin/Index"))" asp-page="/Admin/Index">
                    <i class="fas fa-tachometer-alt"></i> <span>Tổng Quan</span>
                </a>
                <a class="@(navClass("/Admin/Employees"))" asp-page="/Admin/Employees">
                    <i class="fas fa-users-cog"></i> <span>Nhân Viên</span>
                </a>
                <a class="@(navClass("/Admin/Customers"))" asp-page="/Admin/Customers">
                    <i class="fas fa-user-friends"></i> <span>Khách Hàng</span>
                </a>
                <a class="@(navClass("/Admin/Vehicles"))" asp-page="/Admin/Vehicles">
                    <i class="fas fa-car"></i> <span>Quản Lý Xe</span>
                </a>
                <a class="@(navClass("/Admin/Parts"))" asp-page="/Admin/Parts">
                    <i class="fas fa-cogs"></i> <span>Phụ Tùng</span>
                </a>
                <a class="@(navClass("/Admin/Services"))" asp-page="/Admin/Services">
                    <i class="fas fa-clipboard-list"></i> <span>Dịch Vụ</span>
                </a>
                <a class="@(navClass("/Admin/Reports"))" asp-page="/Admin/Reports">
                    <i class="fas fa-chart-bar"></i> <span>Báo Cáo</span>
                </a>
                <a class="@(navClass("/Admin/Permissions"))" asp-page="/Admin/Permissions">
                    <i class="fas fa-user-shield"></i> <span>Quản lý quyền</span>
                </a>
                <a class="@(navClass("/Admin/Reminders"))" asp-page="/Admin/Reminders">
                    <i class="fas fa-bell"></i> <span>Nhắc Bảo Dưỡng</span>
                </a>
                <a class="@(navClass("/Admin/Settings"))" asp-page="/Admin/Settings">
                    <i class="fas fa-cog"></i> <span>Cài Đặt</span>
                </a>
            </nav>
        </aside>

        <div class="admin-main flex-grow-1">
            <header class="admin-topbar d-flex justify-content-between align-items-center">
                <div class="admin-topbar-title">
                    <h1 class="h5 mb-0">@title</h1>
                </div>
                <div class="admin-topbar-user d-flex align-items-center gap-3">
                    <div class="text-end">
                        <div class="small fw-semibold">Quản Trị Viên</div>
                        <div class="small text-muted">Quản Trị Viên</div>
                    </div>
                    <form method="post" asp-page="/Logout" class="m-0">
                        <button type="submit" class="btn btn-sm btn-danger">Đăng Xuất</button>
                    </form>
                </div>
            </header>

            <main class="admin-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>