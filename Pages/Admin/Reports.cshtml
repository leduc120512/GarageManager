@page
@model AutoGarageManager.Pages.Admin.ReportsModel
@{
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Báo Cáo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Báo Cáo</h2>
    <a class="btn btn-dark" href="#">Tạo báo cáo mới</a>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <h5 class="card-title">Xe sửa nhiều nhất</h5>
                <p class="card-text">Xe 29A-12345 (12 lần sửa)</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <h5 class="card-title">Doanh thu tháng</h5>
                <p class="card-text">120.000.000₫</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <h5 class="card-title">Số khách hàng mới</h5>
                <p class="card-text">45</p>
            </div>
        </div>
    </div>
</div>
