@page
@model AutoGarageManager.Pages.Admin.VehiclesModel
@{
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản Lý Xe";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Quản Lý Xe</h2>
    <a class="btn btn-dark" asp-page="./Vehicles/Create">+ Thêm Xe</a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Biển số</th>
                    <th>Model</th>
                    <th>Chủ xe</th>
                    <th>Năm</th>
                    <th style="width: 160px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var vehicle in Model.Vehicles)
                {
                    <tr>
                        <td>@vehicle.LicensePlate</td>
                        <td>@vehicle.Make @vehicle.Model</td>
                        <td>@vehicle.Customer?.FullName</td>
                        <td>@vehicle.Year</td>
                        <td>
                            <a class="text-decoration-none" asp-page="./Vehicles/Edit" asp-route-id="@vehicle.Id">Sửa</a>
                            <span class="mx-1">|</span>
                            <a class="text-decoration-none text-danger" asp-page="./Vehicles/Delete" asp-route-id="@vehicle.Id">Xóa</a>
                        </td>
                    </tr>
                }
                @if (!Model.Vehicles.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">Chưa có xe nào</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
