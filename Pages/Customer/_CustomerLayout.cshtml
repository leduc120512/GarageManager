@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="customer-layout">
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar Navigation -->
            <div class="col-lg-3 col-xl-2 position-sticky top-0" style="height: 100vh; overflow-y: auto; background: linear-gradient(180deg, #f8f9fa 0%, #f0f3f7 100%);">
                <nav class="customer-sidebar py-4">
                    <div class="px-3 mb-4">
                        <h6 class="text-uppercase fw-bold text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Menu</h6>
                    </div>
                    
                    <ul class="nav flex-column gap-2">
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-3 px-3 py-2 rounded-3" 
                               asp-page="./Index"
                               style="color: #6c757d; transition: all 0.3s ease;">
                                <i class="fas fa-home" style="width: 20px; text-align: center;"></i>
                                <span>Trang chủ</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-3 px-3 py-2 rounded-3" 
                               asp-page="./Vehicles"
                               style="color: #6c757d; transition: all 0.3s ease;">
                                <i class="fas fa-car" style="width: 20px; text-align: center;"></i>
                                <span>Xe của tôi</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-3 px-3 py-2 rounded-3" 
                               asp-page="./Reminders"
                               style="color: #6c757d; transition: all 0.3s ease;">
                                <i class="fas fa-bell" style="width: 20px; text-align: center;"></i>
                                <span>Nhắc bảo dưỡng</span>
                                @if (ViewBag.PendingReminderCount > 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-auto">@ViewBag.PendingReminderCount</span>
                                }
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-3 px-3 py-2 rounded-3" 
                               asp-page="./ServiceHistory"
                               style="color: #6c757d; transition: all 0.3s ease;">
                                <i class="fas fa-tools" style="width: 20px; text-align: center;"></i>
                                <span>Lịch sử sửa chữa</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-3 px-3 py-2 rounded-3" 
                               asp-page="./Support"
                               style="color: #6c757d; transition: all 0.3s ease;">
                                <i class="fas fa-headset" style="width: 20px; text-align: center;"></i>
                                <span>Hỗ trợ</span>
                            </a>
                        </li>
                    </ul>

                    <hr class="my-4">

                    <div class="px-3">
                        <h6 class="text-uppercase fw-bold text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Tài khoản</h6>
                    </div>
                    
                    <ul class="nav flex-column gap-2">
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-3 px-3 py-2 rounded-3" 
                               asp-page="/Profile"
                               style="color: #6c757d; transition: all 0.3s ease;">
                                <i class="fas fa-user" style="width: 20px; text-align: center;"></i>
                                <span>Hồ sơ</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-3 px-3 py-2 rounded-3" 
                               asp-page="/Logout"
                               style="color: #6c757d; transition: all 0.3s ease;">
                                <i class="fas fa-sign-out-alt" style="width: 20px; text-align: center;"></i>
                                <span>Đăng xuất</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9 col-xl-10">
                <div style="background: linear-gradient(to right, rgba(13, 110, 253, 0.03), transparent);">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .customer-sidebar a.nav-link {
        position: relative;
        color: #6c757d !important;
    }

    .customer-sidebar a.nav-link:hover {
        background-color: rgba(13, 110, 253, 0.1) !important;
        color: #0d6efd !important;
    }

    .customer-sidebar a.nav-link.active,
    .customer-sidebar a.nav-link[href*="@(ViewContext.HttpContext.Request.Path.Value)"] {
        background-color: rgba(13, 110, 253, 0.15) !important;
        color: #0d6efd !important;
        font-weight: 600;
    }

    .customer-sidebar a.nav-link::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 4px;
        height: 0;
        background: var(--gradient-primary);
        border-radius: 0 2px 2px 0;
        transition: height 0.3s ease;
    }

    .customer-sidebar a.nav-link:hover::before,
    .customer-sidebar a.nav-link.active::before {
        height: 100%;
    }
</style>
