@page
@model AutoGarageManager.Pages.Customer.RemindersModel
@{
    ViewData["Title"] = "Nhắc bảo dưỡng";
    Layout = "~/Pages/Customer/_CustomerLayout.cshtml";
}

<div class="py-4 px-3 px-lg-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-6 fw-bold mb-2">🔔 Nhắc bảo dưỡng</h1>
            <p class="text-muted lead">Theo dõi các nhắc nhở bảo dưỡng của xe bạn</p>
        </div>
        <a class="btn btn-outline-primary" asp-page="./Vehicles">
            <i class="fas fa-car me-2"></i>Quay lại xe
        </a>
    </div>

    @{
        var pendingReminders = Model.Reminders.Where(r => !r.IsCompleted).ToList();
        var completedReminders = Model.Reminders.Where(r => r.IsCompleted).ToList();
    }

    <!-- Stats -->
    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <h3 class="mb-0 fw-bold text-primary">@Model.Reminders.Count</h3>
                    <p class="text-muted small mb-0">Tổng cộng</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <h3 class="mb-0 fw-bold" style="color: #ffc107;">@pendingReminders.Count</h3>
                    <p class="text-muted small mb-0">Đang chờ xử lý</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <h3 class="mb-0 fw-bold text-success">@completedReminders.Count</h3>
                    <p class="text-muted small mb-0">Đã hoàn thành</p>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Reminders.Any())
    {
        <!-- Empty State -->
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <div style="font-size: 4rem; color: #0d6efd; margin-bottom: 1rem;">
                    <i class="fas fa-bell-slash"></i>
                </div>
                <h4 class="fw-bold mb-2">Không có nhắc nào</h4>
                <p class="text-muted mb-4">Bạn không có nhắc bảo dưỡng nào. Hãy thêm xe để nhận được nhắc nhở.</p>
                <a class="btn btn-primary" asp-page="./Vehicles">
                    <i class="fas fa-car me-2"></i>Quản lý xe
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Pending Reminders -->
        @if (pendingReminders.Any())
        {
            <div class="mb-5">
                <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="fas fa-exclamation-circle text-warning"></i>
                    Đang chờ xử lý (@pendingReminders.Count)
                </h5>

                <div class="row g-3">
                    @foreach (var reminder in pendingReminders.OrderBy(r => r.ReminderDate))
                    {
                        var isOverdue = reminder.ReminderDate < DateTime.Now;
                        var daysUntil = (reminder.ReminderDate - DateTime.Now).TotalDays;

                        <div class="col-md-6 col-lg-4">
                            <div class="card border-0 shadow-sm h-100 reminder-card @(isOverdue ? "border-danger" : "")">
                                <div class="card-body">
                                    <!-- Status Badge -->
                                    <div class="mb-3">
                                        @if (isOverdue)
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-clock me-1"></i>Quá hạn
                                            </span>
                                        }
                                        else if (daysUntil < 7)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-exclamation-triangle me-1"></i>Sắp tới
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">
                                                <i class="fas fa-calendar me-1"></i>Sắp tới
                                            </span>
                                        }
                                    </div>

                                    <!-- Reminder Info -->
                                    <h6 class="fw-bold mb-2">@reminder.Title</h6>

                                    <div class="mb-3">
                                        <p class="small text-muted mb-2">
                                            <i class="fas fa-car me-2"></i>@reminder.Vehicle?.LicensePlate
                                        </p>
                                        <p class="small text-muted mb-0">
                                            <i class="fas fa-calendar me-2"></i>@reminder.ReminderDate.ToString("dd/MM/yyyy")
                                        </p>
                                    </div>

                                    @if (!string.IsNullOrEmpty(reminder.Message))
                                    {
                                        <div class="alert alert-light small mb-3">
                                            @reminder.Message
                                        </div>
                                    }

                                    <!-- Mark as Complete -->
                                    <form method="post" asp-page-handler="Complete" style="display: inline;">
                                        <input type="hidden" name="id" value="@reminder.Id" />
                                        <button type="submit" class="btn btn-success btn-sm w-100">
                                            <i class="fas fa-check-circle me-2"></i>Đánh dấu hoàn thành
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Completed Reminders -->
        @if (completedReminders.Any())
        {
            <div class="mb-5">
                <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="fas fa-check-circle text-success"></i>
                    Đã hoàn thành (@completedReminders.Count)
                </h5>

                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tiêu đề</th>
                                    <th>Xe</th>
                                    <th>Ngày nhắc</th>
                                    <th>Ghi chú</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reminder in completedReminders)
                                {
                                    <tr style="opacity: 0.7;">
                                        <td>
                                            <i class="fas fa-check-circle text-success me-2"></i>
                                            @reminder.Title
                                        </td>
                                        <td>@reminder.Vehicle?.LicensePlate</td>
                                        <td>@reminder.ReminderDate.ToString("dd/MM/yyyy")</td>
                                        <td>@reminder.Message</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    .reminder-card {
        transition: all 0.3s ease;
        border: 2px solid transparent !important;
    }

    .reminder-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.1) !important;
        border-color: #0d6efd !important;
    }

    .reminder-card.border-danger {
        border-color: #dc3545 !important;
        background-color: rgba(220, 53, 69, 0.03) !important;
    }
</style>