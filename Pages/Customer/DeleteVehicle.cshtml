@page "{id:int}"
@model AutoGarageManager.Pages.Customer.DeleteVehicleModel
@{
    ViewData["Title"] = "Xóa xe";
    Layout = "~/Pages/Customer/_CustomerLayout.cshtml";
}

<div class="py-4 px-3 px-lg-4">
    <!-- Header -->
    <div class="mb-5">
        <h1 class="display-6 fw-bold mb-2">⚠️ Xóa xe</h1>
        <p class="text-muted lead">Bạn có chắc chắn muốn xóa xe này không?</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm border-danger">
                <div class="card-body p-4">
                    <!-- Vehicle Info -->
                    <div class="alert alert-warning mb-4" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <strong>Lưu ý:</strong> Hành động này không thể hoàn tác. Toàn bộ thông tin liên quan đến xe sẽ
                        bị xóa.
                    </div>

                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <h5 class="fw-bold mb-3">Thông tin xe</h5>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="text-muted small fw-bold mb-1 d-block">Hãng & Model</label>
                                    <p class="mb-0 fw-600">@Model.Vehicle.Make @Model.Vehicle.Model
                                        (@Model.Vehicle.Year)</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="text-muted small fw-bold mb-1 d-block">Biển số xe</label>
                                        <p class="mb-0 fw-600">@Model.Vehicle.LicensePlate</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="text-muted small fw-bold mb-1 d-block">Km hiện tại</label>
                                        <p class="mb-0 fw-600">@Model.Vehicle.Mileage km</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="text-muted small fw-bold mb-1 d-block">ID xe</label>
                                        <p class="mb-0 fw-600">#@Model.Vehicle.Id</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Delete Info -->
                        <div class="alert alert-danger mb-4">
                            <h6 class="fw-bold mb-2">
                                <i class="fas fa-trash-alt me-2"></i>
                                Dữ liệu sẽ bị xóa
                            </h6>
                            <ul class="mb-0 small">
                                <li>Thông tin xe</li>
                                <li>Lịch sử sửa chữa</li>
                                <li>Nhắc bảo dưỡng</li>
                                <li>Tất cả các bản ghi liên quan</li>
                            </ul>
                        </div>

                        <!-- Confirmation -->
                        <form method="post">
                            <div class="mb-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="confirm" required>
                                    <label class="form-check-label" for="confirm">
                                        Tôi hiểu rằng hành động này không thể hoàn tác
                                    </label>
                                </div>
                            </div>

                            <!-- Actions -->
                            <div class="d-grid gap-2 gap-sm-3 d-sm-flex">
                                <button type="submit" class="btn btn-danger btn-lg">
                                    <i class="fas fa-trash-alt me-2"></i>Xác nhận xóa
                                </button>
                                <a asp-page="./Vehicles" class="btn btn-outline-secondary btn-lg">
                                    <i class="fas fa-times me-2"></i>Hủy
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Help -->
                <div class="alert alert-info mt-4">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Cần hỗ trợ?</strong>
                    <a asp-page="./Support" class="text-decoration-none">Liên hệ với chúng tôi</a> nếu bạn có bất kỳ câu hỏi
                    nào.
                </div>
            </div>
        </div>
    </div>

    <style>
        .fw-600 {
            font-weight: 600;
        }
    </style>