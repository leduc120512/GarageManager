@page
@model AutoGarageManager.Pages.Mechanic.ProcessImprovementsModel
@{
    Layout = "/Pages/Mechanic/_MechanicLayout.cshtml";
    ViewData["Title"] = "Nâng cấp quy trình";
}

<div class="container py-4">
    <h2 class="mb-3">Nâng cấp quy trình</h2>
    <p class="text-muted">Gợi ý các cải tiến quy trình để công việc của thợ sửa nhanh hơn và chính xác hơn.</p>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <ul class="list-group list-group-flush">
                @foreach (var item in Model.Suggestions)
                {
                    <li class="list-group-item">
                        <h6 class="mb-1">@item.Title</h6>
                        <p class="mb-0">@item.Description</p>
                    </li>
                }
            </ul>
        </div>
    </div>

    <div class="mt-4">
        <a class="btn btn-outline-primary" asp-page="./Index">Quay lại</a>
    </div>
</div>