@page "{vehicleId:int?}"
@model AutoGarageManager.Pages.Mechanic.ServiceHistoryModel
@{
    Layout = "/Pages/Mechanic/_MechanicLayout.cshtml";
    ViewData["Title"] = $"Lịch sử sửa chữa - {Model.Vehicle?.LicensePlate}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-0">Lịch sử sửa chữa</h2>
        @if (Model.Vehicle != null)
        {
            <p class="text-muted mb-0">Xe: @Model.Vehicle.LicensePlate - @Model.Vehicle.Model</p>
        }
        else
        {
            <p class="text-muted mb-0">Chọn xe để xem lịch sử sửa chữa</p>
        }
    </div>
    @if (Model.Vehicle != null)
    {
        <a class="btn btn-primary" asp-page="/Mechanic/CreateService" asp-route-vehicleId="@Model.VehicleId">+ Tạo lần sửa
            mới</a>
        }
    </div>

    @if (Model.Vehicle != null)
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ngày</th>
                            <th>Mô tả</th>
                            <th>Thợ sửa</th>
                            <th>Tổng tiền</th>
                            <th>Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var history in Model.ServiceHistories)
                        {
                            <tr>
                                <td>@history.ServiceDate.ToString("dd/MM/yyyy")</td>
                                <td>@history.Description</td>
                                <td>@(history.Mechanic?.FullName ?? "N/A")</td>
                                <td>@history.TotalCost.ToString("N0")₫</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" onclick="showDetails(@history.Id)">Xem</button>
                                </td>
                            </tr>
                        }
                        @if (!Model.ServiceHistories.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">Chưa có lịch sử sửa chữa</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <p>Chọn xe để xem lịch sử sửa chữa:</p>
                <ul class="list-group">
                    @foreach (var vehicle in Model.Vehicles)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@vehicle.LicensePlate</strong> - @vehicle.Make @vehicle.Model
                                <div class="text-muted small">@vehicle.Customer?.FullName</div>
                            </div>
                            <a class="btn btn-sm btn-primary" asp-page="/Mechanic/ServiceHistory"
                               asp-route-vehicleId="@vehicle.Id">Xem</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    }

    <!-- Modal for service details -->
    <div class="modal fade" id="serviceDetailsModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Chi tiết lần sửa</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="serviceDetailsContent">
                    <!-- Content will be loaded here -->
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
                async function showDetails(serviceHistoryId) {
                    try {
                        const response = await fetch(`/Mechanic/ServiceDetails?id=${serviceHistoryId}`);
                        const data = await response.text();
                        document.getElementById('serviceDetailsContent').innerHTML = data;
                        new bootstrap.Modal(document.getElementById('serviceDetailsModal')).show();
                    } catch (error) {
                        console.error('Error loading service details:', error);
                    }
                }
        </script>
    }