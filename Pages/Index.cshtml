@page "/"
@model IndexModel
@{
    ViewData["Title"] = "Auto Garage Manager - Gara Sửa Chữa Ô Tô Chuyên Nghiệp";
}

<!-- Enhanced Hero Section -->
<section class="hero-section modern-hero">
    <div class="hero-bg-gradient"></div>
    <div class="animated-bg">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
    </div>
    
    <div class="container-fluid px-4 px-lg-5">
        <div class="row align-items-center min-vh-100">
            <div class="col-lg-6">
                <div class="hero-content">
                    <div class="hero-badge-new">
                        <span class="badge-dot"></span>
                        Nền tảng quản lý gara hiện đại
                    </div>
                    <h1 class="hero-title-new">
                        Quản Lý Gara<br>
                        <span class="gradient-text">Thông Minh & Hiệu Quả</span>
                    </h1>
                    <p class="hero-description-new">
                        Nền tảng quản lý gara toàn diện với công nghệ hiện đại. 
                        Lưu trữ lịch sử sửa chữa, quản lý kho phụ tùng tự động, 
                        nhắc lịch bảo dưỡng, và phân tích doanh thu chi tiết.
                    </p>
                    
                    <div class="hero-stats">
                        <div class="stat-card">
                            <div class="stat-value">1500+</div>
                            <div class="stat-text">Xe quản lý</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-value">98%</div>
                            <div class="stat-text">Hài lòng</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-value">500+</div>
                            <div class="stat-text">Khách hàng</div>
                        </div>
                    </div>
                    
                    <div class="hero-buttons-new">
                        <a href="/Register" class="btn-modern btn-primary-modern">
                            <i class="fas fa-arrow-right me-2"></i>Bắt Đầu Ngay
                        </a>
                        <a href="#services" class="btn-modern btn-secondary-modern">
                            <i class="fas fa-play me-2"></i>Xem Demo
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6">
                <div class="hero-visual">
                    <div class="tech-card">
                        <div class="card-glow"></div>
                        <div class="card-content">
                            <div class="card-icon">
                                <i class="fas fa-chart-line"></i>
                            </div>
                            <div class="card-info">
                                <h3>Dashboard Thực Tế</h3>
                                <p>Giám sát toàn bộ hoạt động</p>
                            </div>
                        </div>
                        <div class="chart-mock">
                            <div class="bar" style="height: 40%"></div>
                            <div class="bar" style="height: 60%"></div>
                            <div class="bar" style="height: 80%"></div>
                            <div class="bar" style="height: 50%"></div>
                        </div>
                    </div>
                    
                    <div class="floating-cards">
                        <div class="float-card fc-1">
                            <i class="fas fa-wrench"></i>
                            <span>Bảo dưỡng</span>
                        </div>
                        <div class="float-card fc-2">
                            <i class="fas fa-boxes"></i>
                            <span>Phụ tùng</span>
                        </div>
                        <div class="float-card fc-3">
                            <i class="fas fa-history"></i>
                            <span>Lịch sử</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="scroll-indicator">
        <div class="scroll-dot"></div>
    </div>
</section>

<!-- Services Section -->

<!-- Modern Services Section -->
<section id="services" class="services-section-modern py-6">
    <div class="container-fluid px-4 px-lg-5">
        <div class="section-header-modern text-center mb-5">
            <span class="section-badge-modern">
                <i class="fas fa-star"></i>
                TÍNH NĂNG CHÍNH
            </span>
            <h2 class="section-title-modern">Giải Pháp Toàn Diện</h2>
            <p class="section-subtitle-modern">
                Các tính năng mạnh mẽ được thiết kế để tối ưu hóa quy trình hoạt động của gara
            </p>
        </div>
        
        <div class="services-grid">
            <!-- Service 1 -->
            <div class="service-card-modern">
                <div class="service-icon-wrapper">
                    <div class="icon-bg"></div>
                    <i class="fas fa-history"></i>
                </div>
                <h3>Lịch Sử Sửa Chữa</h3>
                <p>Lưu trữ đầy đủ và chi tiết mọi hạng mục sửa chữa, thay thế phụ tùng cho từng xe.</p>
                <ul class="feature-list">
                    <li><i class="fas fa-check"></i> Tra cứu nhanh theo biển số</li>
                    <li><i class="fas fa-check"></i> Xuất báo cáo tự động</li>
                    <li><i class="fas fa-check"></i> Lịch sử chi tiết</li>
                </ul>
                <a href="#" class="learn-more">Tìm hiểu thêm <i class="fas fa-arrow-right ms-2"></i></a>
            </div>
            
            <!-- Service 2 -->
            <div class="service-card-modern">
                <div class="service-icon-wrapper">
                    <div class="icon-bg"></div>
                    <i class="fas fa-boxes"></i>
                </div>
                <h3>Quản Lý Kho</h3>
                <p>Kiểm soát tồn kho phụ tùng theo thời gian thực, giảm thất thoát và nhầm lẫn.</p>
                <ul class="feature-list">
                    <li><i class="fas fa-check"></i> Quản lý barcode</li>
                    <li><i class="fas fa-check"></i> Cảnh báo tồn kho thấp</li>
                    <li><i class="fas fa-check"></i> Theo dõi đặt hàng</li>
                </ul>
                <a href="#" class="learn-more">Tìm hiểu thêm <i class="fas fa-arrow-right ms-2"></i></a>
            </div>
            
            <!-- Service 3 -->
            <div class="service-card-modern">
                <div class="service-icon-wrapper">
                    <div class="icon-bg"></div>
                    <i class="fas fa-bell"></i>
                </div>
                <h3>Nhắc Lịch Bảo Dưỡng</h3>
                <p>Hệ thống tự động nhắc nhở khách hàng qua SMS về lịch bảo dưỡng định kỳ.</p>
                <ul class="feature-list">
                    <li><i class="fas fa-check"></i> Gửi SMS tự động</li>
                    <li><i class="fas fa-check"></i> Cài đặt linh hoạt</li>
                    <li><i class="fas fa-check"></i> Tăng tỷ lệ tái ngành</li>
                </ul>
                <a href="#" class="learn-more">Tìm hiểu thêm <i class="fas fa-arrow-right ms-2"></i></a>
            </div>
            
            <!-- Service 4 -->
            <div class="service-card-modern">
                <div class="service-icon-wrapper">
                    <div class="icon-bg"></div>
                    <i class="fas fa-chart-bar"></i>
                </div>
                <h3>Báo Cáo & Analytics</h3>
                <p>Phân tích chi tiết doanh thu, lợi nhuận và hiệu suất hoạt động gara.</p>
                <ul class="feature-list">
                    <li><i class="fas fa-check"></i> Dashboard thực tế</li>
                    <li><i class="fas fa-check"></i> Xuất báo cáo PDF</li>
                    <li><i class="fas fa-check"></i> Thống kê doanh số</li>
                </ul>
                <a href="#" class="learn-more">Tìm hiểu thêm <i class="fas fa-arrow-right ms-2"></i></a>
            </div>
            
            <!-- Service 5 -->
            <div class="service-card-modern">
                <div class="service-icon-wrapper">
                    <div class="icon-bg"></div>
                    <i class="fas fa-users"></i>
                </div>
                <h3>Quản Lý Khách Hàng</h3>
                <p>Tổ chức thông tin khách hàng, quản lý liên hệ và theo dõi mối quan hệ.</p>
                <ul class="feature-list">
                    <li><i class="fas fa-check"></i> Hồ sơ khách hàng</li>
                    <li><i class="fas fa-check"></i> Lịch sử giao dịch</li>
                    <li><i class="fas fa-check"></i> Phân loại VIP</li>
                </ul>
                <a href="#" class="learn-more">Tìm hiểu thêm <i class="fas fa-arrow-right ms-2"></i></a>
            </div>
            
            <!-- Service 6 -->
            <div class="service-card-modern">
                <div class="service-icon-wrapper">
                    <div class="icon-bg"></div>
                    <i class="fas fa-lock"></i>
                </div>
                <h3>Phân Quyền An Toàn</h3>
                <p>Quản lý quyền truy cập cho từng role: Admin, Thợ, Kế toán, Khách hàng.</p>
                <ul class="feature-list">
                    <li><i class="fas fa-check"></i> Kiểm soát quyền hạn</li>
                    <li><i class="fas fa-check"></i> Tạo các vai trò</li>
                    <li><i class="fas fa-check"></i> Bảo mật dữ liệu</li>
                </ul>
                <a href="#" class="learn-more">Tìm hiểu thêm <i class="fas fa-arrow-right ms-2"></i></a>
            </div>
        </div>
    </div>
</section>

