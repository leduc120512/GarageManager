@page
@model AutoGarageManager.Pages.Accountant.InvoiceDetailsModel

<div class="invoice-details">
    @if (Model.Invoice != null)
    {
        <div class="text-center mb-4">
            <h4>HÓA ĐƠN SỬA CHỮA</h4>
            <p>Mã hóa đơn: HD@Model.Invoice.Id.ToString("D4")</p>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <strong>Thông tin khách hàng:</strong><br>
                @Model.Invoice.Vehicle.Customer.FullName<br>
                @Model.Invoice.Vehicle.Customer.Phone<br>
                @Model.Invoice.Vehicle.Customer.Email
            </div>
            <div class="col-md-6">
                <strong>Thông tin xe:</strong><br>
                Biển số: @Model.Invoice.Vehicle.LicensePlate<br>
                Model: @Model.Invoice.Vehicle.Model<br>
                Năm: @Model.Invoice.Vehicle.Year
            </div>
        </div>

        <div class="mb-3">
            <strong>Ngày sửa chữa:</strong> @Model.Invoice.ServiceDate.ToString("dd/MM/yyyy HH:mm")
        </div>

        <div class="mb-3">
            <strong>Mô tả công việc:</strong><br>
            @Model.Invoice.Description
        </div>

        @if (Model.Invoice.ServicesPerformed.Any())
        {
            <div class="mb-3">
                <strong>Dịch vụ đã thực hiện:</strong>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Tên dịch vụ</th>
                            <th>Giá</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var service in Model.Invoice.ServicesPerformed)
                        {
                            <tr>
                                <td>@service.Service.Name</td>
                                <td>@service.Price.ToString("N0")₫</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.Invoice.PartsUsed.Any())
        {
            <div class="mb-3">
                <strong>Phụ tùng đã sử dụng:</strong>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Tên phụ tùng</th>
                            <th>SL</th>
                            <th>Đơn giá</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var part in Model.Invoice.PartsUsed)
                        {
                            <tr>
                                <td>@part.Part.Name</td>
                                <td>@part.Quantity</td>
                                <td>@part.UnitPrice.ToString("N0")₫</td>
                                <td>@((part.Quantity * part.UnitPrice).ToString("N0"))₫</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="text-end">
            <h5>Tổng tiền: @Model.Invoice.TotalCost.ToString("N0")₫</h5>
        </div>
    }
    else
    {
        <p class="text-muted">Không tìm thấy hóa đơn.</p>
    }
</div>
