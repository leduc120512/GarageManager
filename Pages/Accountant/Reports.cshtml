@page
@model AutoGarageManager.Pages.Accountant.ReportsModel
@{
    Layout = "/Pages/Accountant/_AccountantLayout.cshtml";
    ViewData["Title"] = "Báo cáo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Báo cáo</h2>
    <div>
        <select id="reportType" class="form-select d-inline-block w-auto me-2">
            <option value="monthly">Báo cáo tháng</option>
            <option value="yearly">Báo cáo năm</option>
            <option value="parts">Báo cáo phụ tùng</option>
        </select>
        <button class="btn btn-primary" onclick="generateReport()">Tạo báo cáo</button>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center">
                <h5 class="card-title">Doanh thu tháng này</h5>
                <h3 class="text-success">@Model.MonthlyRevenue.ToString("N0")₫</h3>
                <small class="text-muted">So với tháng trước: +15%</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center">
                <h5 class="card-title">Số hóa đơn</h5>
                <h3 class="text-primary">@Model.TotalInvoices</h3>
                <small class="text-muted">Tháng này</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center">
                <h5 class="card-title">Khách hàng mới</h5>
                <h3 class="text-info">@Model.NewCustomers</h3>
                <small class="text-muted">Tháng này</small>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-white border-0">
        <h2 class="h6 mb-0">Báo cáo chi tiết</h2>
    </div>
    <div class="card-body">
        <canvas id="revenueChart" width="400" height="200"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart').getContext('2d');
        const chart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.ChartLabels)),
                datasets: [{
                    label: 'Doanh thu (₫)',
                    data: @Html.Raw(Json.Serialize(Model.ChartData)),
                    borderColor: 'rgb(75, 192, 192)',
                    tension: 0.1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return new Intl.NumberFormat('vi-VN').format(value) + '₫';
                            }
                        }
                    }
                }
            }
        });

        function generateReport() {
            const type = document.getElementById('reportType').value;
            window.open(`/Accountant/ExportReport?type=${type}`, '_blank');
        }
    </script>
}
