@page
@model AutoGarageManager.Pages.Accountant.CustomersModel
@{
    Layout = "/Pages/Accountant/_AccountantLayout.cshtml";
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Quản lý khách hàng</h2>
</div>

@if (Model.IsViewing && Model.SelectedCustomer != null)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5>Thông tin khách hàng</h5>
            <p><strong>Tên:</strong> @Model.SelectedCustomer.FullName</p>
            <p><strong>Email:</strong> @Model.SelectedCustomer.Email</p>
            <p><strong>Điện thoại:</strong> @Model.SelectedCustomer.Phone</p>
            <p><strong>Địa chỉ:</strong> @Model.SelectedCustomer.Address</p>
            <p><strong>Số xe:</strong> @Model.SelectedCustomer.Vehicles.Count</p>
            <a class="btn btn-secondary" asp-page="./Customers">Đóng</a>
        </div>
    </div>
}

@if (Model.IsEditing && Model.SelectedCustomer != null)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5>Sửa thông tin khách hàng</h5>
            <form method="post" asp-page-handler="Edit">
                <input asp-for="InputCustomer.Id" type="hidden" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Họ và tên</label>
                        <input asp-for="InputCustomer.FullName" class="form-control" />
                        <span asp-validation-for="InputCustomer.FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input asp-for="InputCustomer.Email" class="form-control" />
                        <span asp-validation-for="InputCustomer.Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Điện thoại</label>
                        <input asp-for="InputCustomer.Phone" class="form-control" />
                        <span asp-validation-for="InputCustomer.Phone" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Địa chỉ</label>
                        <input asp-for="InputCustomer.Address" class="form-control" />
                        <span asp-validation-for="InputCustomer.Address" class="text-danger"></span>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Lưu</button>
                    <a class="btn btn-secondary" asp-page="./Customers">Hủy</a>
                </div>
            </form>
        </div>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Tên</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Số xe</th>
                    <th>Tổng chi tiêu</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model.Customers)
                {
                    <tr>
                        <td>@customer.FullName</td>
                        <td>@customer.Phone</td>
                        <td>@customer.Email</td>
                        <td>@customer.Vehicles.Count</td>
                        <td>
                            @{
                                var totalSpent = Model.CustomerTotals.FirstOrDefault(ct => ct.CustomerId == customer.Id)?.Total ?? 0;
                            }
                            @totalSpent.ToString("N0")₫
                        </td>
                        <td>
                            <a class="text-decoration-none me-2" asp-page="./Customers" asp-route-viewId="@customer.Id">Xem chi tiết</a>
                            <a class="text-decoration-none" asp-page="./Customers" asp-route-editId="@customer.Id">Sửa</a>
                        </td>
                    </tr>
                }
                @if (!Model.Customers.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">Chưa có khách hàng nào</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
